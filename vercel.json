{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/main.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/main.py": {
      "runtime": "vercel-python@4.2.0",
      "maxDuration": 30
    }
  }
}
